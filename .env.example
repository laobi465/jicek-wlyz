# =============================================================================
# 网络验证 SaaS 系统 - 环境变量示例
# 复制本文件为 .env 并填入实际值；生产环境由 deploy/install.sh 自动生成
# =============================================================================

# ---------- 应用 ----------
# 应用端口
APP_PORT=3000
# 应用镜像（生产部署用，开发环境留空）
APP_IMAGE=ghcr.io/laobi465/jicek-wlyz:latest

# ---------- 数据库（PostgreSQL 16）----------
# 开发环境直连本机 Postgres；生产环境由 docker-compose 注入
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/jicek_wlyz?schema=public
DB_PORT=5432
DB_NAME=jicek_wlyz
DB_PASSWORD=your_db_password

# ---------- Redis 7 ----------
# redis/index.ts 读取 host/port/password（非 url）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ---------- Better Auth 鉴权 ----------
# auth.ts 读取，变量名必须一致
# SECRET 用 `openssl rand -hex 32` 生成
BETTER_AUTH_SECRET=your_better_auth_secret
# 应用外部可访问地址（生产环境改为实际域名）
BETTER_AUTH_URL=http://localhost:3000

# ---------- 敏感字段加密 ----------
# crypto-field.ts 读取，AES-256-GCM 主密钥，用 `openssl rand -hex 32` 生成
FIELD_ENCRYPTION_KEY=your_field_encryption_key

# ---------- 主密钥（AES 加密业务密钥）----------
# app-service / card-key-service / epay-service 读取，经 SHA-256 派生为
# AES-256 密钥，用于加密开发者应用的 RSA 私钥 / 卡密水印 / 易支付密钥。
# 用 `openssl rand -hex 32` 生成。
# ⚠️ 生成后不可更改，否则已加密数据无法解密
MASTER_KEY=your_master_key

# ---------- 平台 RSA 私钥（卡密/云变量签名）----------
# card-key-service / cloud-variable-service 读取，用于卡密 RSA 签名与
# 云变量签名。生成命令（base64 编码的 PEM，单行存储避免换行问题）：
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | base64 -w 0
# 运行时 loadPrivateKeyFromEnv() 自动解码还原 PEM。
# 也支持直接粘贴 PEM 原文（以 -----BEGIN 开头）。
# ⚠️ 生成后不可更改，否则已签发的卡密/云变量签名校验会失败
PLATFORM_RSA_PRIVATE_KEY=your_base64_encoded_rsa_private_key

# ---------- GitHub 仓库配置（更新面板 / Webhook）----------
# update-service 读取，用于检查更新与执行 git pull 更新。
# github webhook 路由读取 GITHUB_REPO_BRANCH 校验推送分支。
GITHUB_REPO_URL=https://github.com/laobi465/jicek-wlyz.git
GITHUB_REPO_BRANCH=main

# ---------- 超管 IP 白名单（可选）----------
# JSON 数组格式，如 ["1.2.3.4","10.0.0.0/8"]；未配置则不启用白名单
# SUPER_ADMIN_IP_WHITELIST=[]
